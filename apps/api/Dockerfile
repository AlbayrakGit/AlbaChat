癤풣ROM node:20-alpine AS base
WORKDIR /app

# G횄쩌venlik: root olmayan kullan횆짹c횆짹
RUN addgroup -S AlbaChat && adduser -S AlbaChat -G AlbaChat

# Ba횆타횆짹ml횆짹l횆짹klar횆짹 kur
COPY package.json ./
RUN npm install --omit=dev && npm cache clean --force

# Uygulama kodunu kopyala
COPY src ./src

# Dosya sahipli횆타ini de횆타i횇타tir
RUN chown -R AlbaChat:AlbaChat /app

USER AlbaChat

# Migration + Seed + server ba힊lat
CMD ["sh", "-c", "node src/db/migrate.js && node src/db/seed.js && node src/server.js"]

EXPOSE 3001

# Sa횆타l횆짹k kontrol횄쩌
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3001/health || exit 1

